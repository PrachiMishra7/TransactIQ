generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Upload {
  id                String             @id @default(uuid())
  fileName          String             @map("file_name")
  fileSize          Int                @map("file_size")
  totalRows         Int                @default(0) @map("total_rows")
  validRows         Int                @default(0) @map("valid_rows")
  invalidRows       Int                @default(0) @map("invalid_rows")
  warningRows       Int                @default(0) @map("warning_rows")
  qualityScore      Float              @default(0) @map("quality_score")
  processingStatus  String             @default("PENDING") @map("processing_status")
  ruleVersionId     String?            @map("rule_version_id")
  cleanedFilePath   String?            @map("cleaned_file_path")
  errorFilePath     String?            @map("error_file_path")
  reportFilePath    String?            @map("report_file_path")
  createdAt         DateTime           @default(now()) @map("created_at")
  validationErrors  ValidationError[]
  reports           Report[]

  @@map("uploads")
}

model ValidationError {
  id           String   @id @default(uuid())
  uploadId     String   @map("upload_id")
  rowNumber    Int      @map("row_number")
  columnName   String   @map("column_name")
  errorType    String   @map("error_type")
  errorMessage String   @map("error_message")
  severity     String   @default("MEDIUM")
  createdAt    DateTime @default(now()) @map("created_at")
  upload       Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@map("validation_errors")
}

model ValidationRule {
  id             String   @id @default(uuid())
  countryName    String   @map("country_name")
  countryCode    String   @map("country_code")
  fieldName      String   @map("field_name")
  validationType String   @map("validation_type")
  ruleValue      String   @map("rule_value")
  isActive       Boolean  @default(true) @map("is_active")
  version        Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("validation_rules")
}

model RuleVersion {
  id          String   @id @default(uuid())
  version     Int
  description String?
  ruleSnapshot Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("rule_versions")
}

model Report {
  id           String   @id @default(uuid())
  uploadId     String   @map("upload_id")
  summary      String
  qualityScore Float    @map("quality_score")
  generatedAt  DateTime @default(now()) @map("generated_at")
  upload       Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@map("reports")
}


